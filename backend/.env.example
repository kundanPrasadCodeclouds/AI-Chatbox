# Copy this file to backend/.env before running the backend.
# Never commit backend/.env because it contains your private Hugging Face token.

# Express server settings.
PORT=5000
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:5173

# Set to true only while debugging Hugging Face requests.
DEBUG_HUGGING_FACE=false

# Create a free token from your Hugging Face account settings.
HUGGING_FACE_API_TOKEN=your_hugging_face_token_here

# This model is currently supported by the free hf-inference provider.
HUGGING_FACE_MODEL=katanemo/Arch-Router-1.5B:hf-inference

# Hugging Face's OpenAI-compatible router endpoint for chat completions.
HUGGING_FACE_API_URL=https://router.huggingface.co/v1/chat/completions
